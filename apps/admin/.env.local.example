# From Supabase: Project Settings -> API. Same project as apps/web -- no
# NEXT_PUBLIC_ prefix because nothing here ships to a browser bundle.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The only Google account allowed into this panel,
# e.g. harin.25bcs10680@sst.scaler.com
ADMIN_EMAIL=

# Secret URL slug that starts the login. Visiting
# https://<admin-app-url>/<this-value> redirects you to Google sign-in;
# every other path (including /) is a 404. Pick something long and random,
# e.g. the output of:  openssl rand -hex 16
ADMIN_ENTRY_SECRET=
