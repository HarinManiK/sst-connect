# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, never exposed to the client. Used by the AI categorization
# job, which needs to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Google AI Studio (Gemini) API key -- free tier. Used for post
# categorization + the AI discovery chat. Get one at
# https://aistudio.google.com/apikey ("Create API key").
GEMINI_API_KEY=

# Optional: the model fallback chain, tried left-to-right. If one is
# rate-limited (HTTP 429) or erroring, the next is used. Only Flash /
# Flash-Lite models are on the free tier. Check
# https://aistudio.google.com/ for the exact names available to your key.
# Defaults to: gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite
