NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to call our own /api/ai/categorize-post route from a server action.
# Local dev: http://localhost:3000 -- production: your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only, never exposed to the client. Used by API routes that need to
# bypass RLS (e.g. AI discovery search across all profiles).
SUPABASE_SERVICE_ROLE_KEY=

# build.nvidia.com API key (free tier), used for post categorization + the
# AI discovery chat. Get one at https://build.nvidia.com -- sign in, open
# any model page (e.g. Llama 3.3 70B Instruct), and grab the API key from
# the "Get API Key" panel.
NVIDIA_API_KEY=

# Optional: override which hosted model to use. Defaults to Llama 3.3 70B
# Instruct if unset.
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Resend, used for college-email verification links + deadline reminders.
RESEND_API_KEY=
